# 複製這個檔成 .env，填入你的值。.env 不會進 git。
# cp .env.example .env

# 系統使用者的長效 token（商業設定 → 系統使用者 → 產生權杖）
META_ACCESS_TOKEN=

# 廣告帳戶 ID，含 act_ 前綴，例如 act_1234567890
META_AD_ACCOUNT_ID=

# Marketing API 版本，用當前最新版即可（可日後調整）
META_API_VERSION=v23.0

# 預設拉多久的資料：today / yesterday / last_7d / last_14d / last_30d / last_90d
META_DATE_PRESET=last_30d
